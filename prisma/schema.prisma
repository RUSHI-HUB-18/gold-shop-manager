// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  passwordHash String
  fullName     String
  email        String?  @unique
  phoneNumber  String?  @unique
  role         String   @default("ADMIN")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  calculations CalculationHistory[]
  bills        Bill[]
}

model GoldRate {
  id        String   @id @default(uuid())
  date      DateTime @unique @db.Date
  rate22K   Float
  rate24K   Float?
  updatedBy String
  updatedAt DateTime @updatedAt
}

model ItemMaster {
  id                  String   @id @default(uuid())
  name                String   @unique
  defaultMakingCharge Float
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  calculations        CalculationHistory[]
  billItems           BillItem[]
}

model SystemSettings {
  id            String   @id @default(uuid())
  gstPercentage Float    @default(3.0)
  
  // Shop details
  shopName      String   @default("Gold Shop Manager")
  shopAddress   String?  @default("123, Gold Plaza, Jewel Street")
  shopPhone     String?  @default("+91 98765 43210")
  shopGstNumber String?  @default("27AAAAA1111A1Z1")
  shopLogo      String?  // File path/URL e.g. "uploads/logo.png"
  invoiceTerms  String?  @default("1. Goods once sold cannot be returned or exchanged. 2. Subject to local jurisdiction.")
  enableQrCode  Boolean  @default(true)

  updatedAt     DateTime @updatedAt
}

model CalculationHistory {
  id             String   @id @default(uuid())
  userId         String
  itemId         String
  customerId     String?
  weight         Float
  purity         String
  goldRate       Float
  makingCharge   Float
  gstPercentage  Float
  finalAmount    Float
  createdAt      DateTime @default(now())

  user           User       @relation(fields: [userId], references: [id])
  item           ItemMaster @relation(fields: [itemId], references: [id])
  customer       Customer?  @relation(fields: [customerId], references: [id])
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

model Customer {
  id           String               @id @default(uuid())
  customerCode String               @unique
  fullName     String
  mobileNumber String               @unique
  email        String?              @unique
  address      String?
  city         String?
  state        String?
  pincode      String?
  gstNumber    String?              @unique
  birthDate    DateTime?
  anniversary  DateTime?
  notes        String?
  status       CustomerStatus       @default(ACTIVE)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  calculations CalculationHistory[]
  bills        Bill[]
}

enum DocumentType {
  INVOICE
  ESTIMATE
  QUOTATION
}

enum BillStatus {
  DRAFT
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum DiscountType {
  FLAT
  PERCENTAGE
}

enum MakingChargeType {
  FLAT
  PERCENTAGE
}

model Bill {
  id                      String        @id @default(uuid())
  documentNumber          String        @unique
  documentType            DocumentType  @default(INVOICE)
  customerId              String?
  userId                  String
  createdByName           String        // Creator display name snapshot
  invoiceDate             DateTime      @default(now())
  status                  BillStatus    @default(COMPLETED)
  paymentStatus           PaymentStatus @default(PAID)
  version                 Int           @default(1)
  
  // Financial breakdowns
  subtotal                Decimal       @db.Decimal(12, 2)
  discountType            DiscountType  @default(FLAT)
  discountValue           Decimal       @default(0.0) @db.Decimal(12, 2)
  discountAmount          Decimal       @default(0.0) @db.Decimal(12, 2)
  taxableAmount           Decimal       @db.Decimal(12, 2)
  gstAmount               Decimal       @db.Decimal(12, 2)
  total                   Decimal       @db.Decimal(12, 2)
  notes                   String?       // General notes

  // Shop Info Snapshots
  storeName               String
  storeAddress            String?
  storePhone              String?
  storeGstNumber          String?
  storeLogoSnapshot       String?
  invoiceTermsSnapshot    String?

  // Customer Info Snapshots
  customerNameSnapshot    String?
  customerMobileSnapshot  String?
  customerAddressSnapshot String?
  customerGstSnapshot     String?

  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  customer                Customer?     @relation(fields: [customerId], references: [id])
  user                    User          @relation(fields: [userId], references: [id])
  items                   BillItem[]
}

model BillItem {
  id                String           @id @default(uuid())
  billId            String
  itemId            String?
  itemNameSnapshot  String
  quantity          Int              @default(1)
  
  // Weights
  grossWeight       Decimal          @db.Decimal(10, 3)
  netWeight         Decimal          @db.Decimal(10, 3)
  stoneWeight       Decimal          @default(0.0) @db.Decimal(10, 3)
  purity            String
  
  // Pricing Snapshots
  goldRate          Decimal          @db.Decimal(10, 2)
  makingChargeType  MakingChargeType @default(FLAT)
  makingChargeValue Decimal          @db.Decimal(10, 2)
  makingChargeAmount Decimal         @db.Decimal(10, 2)
  hallmarkCharge    Decimal          @default(0.0) @db.Decimal(10, 2)
  wastage           Decimal          @default(0.0) @db.Decimal(10, 3)
  
  gstPercentage     Decimal          @db.Decimal(5, 2)
  gstAmount         Decimal          @db.Decimal(12, 2)
  amount            Decimal          @db.Decimal(12, 2)
  remarks           String?

  bill              Bill             @relation(fields: [billId], references: [id], onDelete: Cascade)
  item              ItemMaster?      @relation(fields: [itemId], references: [id])
}
